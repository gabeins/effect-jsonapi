{
	"name": "effect-jsonapi",
	"version": "0.0.0",
	"description": "JSON:API spec support for Effect",
	"keywords": [
		"effect",
		"effect-ts",
		"jsonapi"
	],
	"homepage": "https://npmx.dev/package/effect-jsonapi",
	"bugs": {
		"url": "https://github.com/gabeins/effect-jsonapi/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/gabeins/effect-jsonapi"
	},
	"files": [
		"dist/**/*.js",
		"dist/**/*.js.map",
		"dist/**/*.d.ts",
		"dist/**/*.d.ts.map"
	],
	"type": "module",
	"sideEffects": false,
	"types": "./dist/index.d.ts",
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsc",
		"fmt": "oxfmt",
		"lint": "oxlint --type-aware",
		"test": "vitest --silent --run"
	},
	"dependencies": {
		"effect": "4.0.0-beta.59"
	},
	"devDependencies": {
		"@effect/vitest": "4.0.0-beta.59",
		"@types/node": "^25.6.0",
		"oxfmt": "^0.47.0",
		"oxlint": "^1.62.0",
		"oxlint-tsgolint": "^0.22.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "^11.0.5",
			"onFail": "download"
		}
	}
}
