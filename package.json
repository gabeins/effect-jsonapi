{
	"name": "effect-jsonapi",
	"version": "0.0.0",
	"description": "JSON:API spec support for Effect",
	"keywords": [
		"effect",
		"effect-ts",
		"jsonapi"
	],
	"homepage": "https://github.com/gabeins/effect-jsonapi",
	"bugs": {
		"url": "https://github.com/gabeins/effect-jsonapi/issues"
	},
	"license": "MIT",
	"author": "Gabe Silva",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gabeins/effect-jsonapi.git"
	},
	"files": [
		"dist/**/*.js",
		"dist/**/*.js.map",
		"dist/**/*.d.ts",
		"dist/**/*.d.ts.map"
	],
	"type": "module",
	"sideEffects": false,
	"types": "./dist/index.d.ts",
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsc",
		"clean": "rm -rf dist",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"lint": "oxlint --type-aware",
		"prepack": "pnpm run clean && pnpm run build",
		"test": "vitest --silent --run",
		"verify:package": "publint && attw --pack . --profile esm-only"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.29.5",
		"@effect/vitest": "4.0.0-beta.78",
		"@types/node": "^25.9.2",
		"oxfmt": "^0.54.0",
		"oxlint": "^1.69.0",
		"oxlint-tsgolint": "^0.23.0",
		"publint": "^0.3.12",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"peerDependencies": {
		"effect": "4.0.0-beta.78"
	},
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@11.5.2"
}
